<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>GTAVOfflineModLauncher</AssemblyName>
    <RootNamespace>GtavOfflineModLauncher</RootNamespace>
    <ApplicationIcon>Assets\GtavLauncher.ico</ApplicationIcon>
    <Product>GTA V Offline Mod Launcher</Product>
    <Description>Launcher and installer for GTA V Offline add-on vehicle mods.</Description>
    <Version>1.0.0</Version>
    <FileVersion>1.0.0.0</FileVersion>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Assets\GtavLauncher.png" />
    <Resource Include="Assets\GtavLauncher.ico" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CodeWalker.Core" Version="1.0.3" />
  </ItemGroup>

</Project>
