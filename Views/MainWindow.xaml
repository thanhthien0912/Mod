<Window x:Class="GtavOfflineModLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GTA V Offline Mod Launcher"
        Height="820"
        Width="1280"
        MinHeight="720"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8FAFC"
        Icon="pack://application:,,,/Assets/GtavLauncher.ico"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <!-- Color Palette & Brushes (Light Theme) -->
        <SolidColorBrush x:Key="WindowBgBrush" Color="#FFF8FAFC" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE2E8F0" />
        <SolidColorBrush x:Key="TextBrush" Color="#FF0F172A" />
        <SolidColorBrush x:Key="MutedBrush" Color="#FF64748B" />
        <SolidColorBrush x:Key="TitleBrush" Color="#FF0F172A" />
        
        <SolidColorBrush x:Key="AccentBrush" Color="#FF059669" /> <!-- Emerald 600 -->
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF047857" /> <!-- Emerald 700 -->
        <SolidColorBrush x:Key="AccentActiveBrush" Color="#FF065F46" /> <!-- Emerald 800 -->
        <SolidColorBrush x:Key="AccentLightBrush" Color="#FFECFDF5" /> <!-- Emerald 50 -->
        <SolidColorBrush x:Key="AccentBorderBrush" Color="#FF10B981" />

        <SolidColorBrush x:Key="DangerBrush" Color="#FFDC2626" /> <!-- Red 600 -->
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#FFB91C1C" /> <!-- Red 700 -->
        <SolidColorBrush x:Key="DangerActiveBrush" Color="#FF991B1B" /> <!-- Red 800 -->
        <SolidColorBrush x:Key="DangerBorderBrush" Color="#FFF87171" />

        <SolidColorBrush x:Key="SecondaryBrush" Color="#FFF1F5F9" /> <!-- Slate 100 -->
        <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#FFE2E8F0" /> <!-- Slate 200 -->
        <SolidColorBrush x:Key="SecondaryActiveBrush" Color="#FFF1F5F9" />
        <SolidColorBrush x:Key="SecondaryBorderBrush" Color="#FFE2E8F0" />

        <SolidColorBrush x:Key="InputBgBrush" Color="#FFF8FAFC" />
        <SolidColorBrush x:Key="InputFocusedBgBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#FFE2E8F0" />

        <!-- Light, fresh gradient header banner -->
        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFECFDF5" Offset="0" />
            <GradientStop Color="#FFE0F2FE" Offset="0.5" />
            <GradientStop Color="#FFF3E8FF" Offset="1" />
        </LinearGradientBrush>

        <!-- Card Style with soft shadow -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Color="#0F172A" Opacity="0.06" ShadowDepth="2" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style (Emerald Green) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Margin" Value="0,0,10,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentActiveBrush}" />
                                <Setter TargetName="Root" Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#FFE2E8F0" />
                                <Setter Property="Foreground" Value="#FF94A3B8" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="Transparent" />
                                <Setter TargetName="Root" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryBorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SecondaryHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFCBD5E1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFE2E8F0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#FFF8FAFC" />
                                <Setter Property="Foreground" Value="#FFCBD5E1" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="Transparent" />
                                <Setter TargetName="Root" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button Style -->
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource DangerHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource DangerActiveBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#FFE2E8F0" />
                                <Setter Property="Foreground" Value="#FF94A3B8" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="Transparent" />
                                <Setter TargetName="Root" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Global TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentLightBrush}" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="{StaticResource InputFocusedBgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="true">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                                <Setter TargetName="border" Property="Background" Value="#FFF1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Global CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent" SnapsToDevicePixels="true">
                            <BulletDecorator.Bullet>
                                <Border x:Name="BulletBorder"
                                        Width="20"
                                        Height="20"
                                        CornerRadius="6"
                                        BorderThickness="2"
                                        BorderBrush="{StaticResource CardBorderBrush}"
                                        Background="{StaticResource InputBgBrush}">
                                    <Path x:Name="CheckMark"
                                          Width="10"
                                          Height="8"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          SnapsToDevicePixels="False"
                                          Stroke="{StaticResource AccentBrush}"
                                          StrokeThickness="2"
                                          Data="M 1,4 L 4,7 L 9,1"
                                          Visibility="Collapsed" />
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="BulletBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="BulletBorder" Property="Background" Value="{StaticResource AccentLightBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="BulletBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ROW 0: Sleek Header Banner (Light Theme) -->
        <Border Grid.Row="0"
                CornerRadius="16"
                Background="{StaticResource HeroBrush}"
                Padding="22"
                BorderBrush="#2010B981"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="80"
                        Height="80"
                        CornerRadius="16"
                        Background="#2010B981"
                        BorderBrush="#4010B981"
                        BorderThickness="1"
                        Padding="12"
                        VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Assets/GtavLauncher.png" Stretch="Uniform" />
                </Border>

                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <WrapPanel Margin="0,0,0,6">
                        <Border Margin="0,0,10,0" Padding="8,4" Background="#FFD1FAE5" CornerRadius="4" BorderBrush="#FF10B981" BorderThickness="1">
                            <TextBlock Foreground="#FF065F46" FontSize="11" FontWeight="Bold" Text="Offline / Story Mode" />
                        </Border>
                        <Border Margin="0,0,10,0" Padding="8,4" Background="#FFECFDF5" CornerRadius="4" BorderBrush="#FF34D399" BorderThickness="1">
                            <TextBlock Foreground="#FF065F46" FontSize="11" FontWeight="Bold" Text="Safe Installation" />
                        </Border>
                    </WrapPanel>

                    <TextBlock FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource TitleBrush}"
                               Text="GTA V Offline Mod Launcher" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#FF475569"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Text="Manage and install your vehicle add-on mods safely. All operations are confined to the 'mods' folder." />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 1: Content Area (2 Columns) -->
        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Column: Install Form & Activity Log -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Install Form Card -->
                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Text="Install a vehicle add-on" />
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Margin="0,6,0,16" Foreground="{StaticResource MutedBrush}" FontSize="12" TextWrapping="Wrap" Text="Select your GTA V folder, pick a dlc.rpf file, and specify the mod details." />

                        <!-- GTA Folder -->
                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" FontSize="12" Text="GTA folder" />
                        <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                            <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButtonStyle}" Content="Browse" Command="{Binding BrowseGtaFolderCommand}" Margin="8,0,0,10" Padding="12,8" Height="38"/>
                            <TextBox Text="{Binding GtaPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Margin="0,0,0,10" Height="38" />
                        </DockPanel>

                        <!-- dlc.rpf file -->
                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" FontSize="12" Text="dlc.rpf file" />
                        <DockPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,10">
                            <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButtonStyle}" Content="Select" Command="{Binding SelectDlcRpfCommand}" Margin="8,0,0,10" Padding="12,8" Height="38"/>
                            <TextBox Text="{Binding SelectedDlcRpfPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Margin="0,0,0,10" Height="38" />
                        </DockPanel>

                        <!-- Mod Name -->
                        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" FontSize="12" Text="Mod folder name" />
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ModName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Height="38" />

                        <!-- Spawn Name -->
                        <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" FontSize="12" Text="Spawn name" />
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding SpawnName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" Height="38" />

                        <!-- Options, Path Preview and Actions -->
                        <StackPanel Grid.Row="6" Grid.ColumnSpan="2">
                            <CheckBox Content="Auto edit dlclist.xml inside update.rpf" IsChecked="{Binding AutoEditDlclist}" Margin="0,0,0,12" FontSize="12"/>
                            
                            <!-- Integrated Path Preview Box (Mint Theme) -->
                            <Border Margin="0,0,0,14" Padding="10" CornerRadius="8" Background="#FFECFDF5" BorderBrush="#FFD1FAE5" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Target dlc.rpf installation preview:" FontSize="10" FontWeight="Bold" Foreground="#FF065F46" />
                                    <TextBlock Text="{Binding TargetInstallPathPreview}" FontSize="11" Foreground="#FF047857" TextWrapping="Wrap" Margin="0,3,0,0" FontFamily="Consolas" />
                                </StackPanel>
                            </Border>

                            <!-- Actions WrapPanel -->
                            <WrapPanel HorizontalAlignment="Left" Margin="0,4,0,0">
                                <Button Style="{StaticResource PrimaryButtonStyle}" Content="Install Mod" Command="{Binding InstallModCommand}" Height="38" Padding="16,0" Margin="0,0,10,8" />
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Launch GTA V" Command="{Binding LaunchGtaOfflineCommand}" Height="38" Padding="16,0" Margin="0,0,10,8" />
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Refresh" Command="{Binding RefreshInstalledModsCommand}" Height="38" Padding="16,0" Margin="0,0,10,8" />
                                <Button Style="{StaticResource DangerButtonStyle}" Content="Uninstall Mod" Command="{Binding UninstallSelectedModCommand}" Height="38" Padding="16,0" Margin="0,0,10,8" />
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Activity Log Card -->
                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Text="Activity Log" />
                        
                        <ListBox x:Name="LogListBox"
                                 Grid.Row="1"
                                 Margin="0,10,0,0"
                                 ItemsSource="{Binding LogEntries}"
                                 Background="#FFF8FAFC"
                                 Foreground="{StaticResource TextBrush}"
                                 BorderBrush="{StaticResource CardBorderBrush}"
                                 BorderThickness="1"
                                 Padding="6"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="0,0,0,4" />
                                    <Setter Property="Padding" Value="8,6" />
                                    <Setter Property="Background" Value="White" />
                                    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right Column: Installed Mods Card -->
            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Text="Installed Mods" />
                        <Border DockPanel.Dock="Right" HorizontalAlignment="Right" Padding="10,4" CornerRadius="4" Background="#FFECFDF5" BorderBrush="#FF059669" BorderThickness="1">
                            <TextBlock Foreground="#FF065F46" FontWeight="Bold" FontSize="11" Text="{Binding InstalledMods.Count, StringFormat=RECORDS: {0}}" />
                        </Border>
                    </DockPanel>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1"
                              Margin="0,14,0,0"
                              ItemsSource="{Binding InstalledMods}"
                              SelectedItem="{Binding SelectedInstalledMod}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#FFF1F5F9"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              Background="Transparent"
                              RowHeaderWidth="0"
                              SelectionUnit="FullRow">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#FFF1F5F9" />
                                <Setter Property="Foreground" Value="#FF475569" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Padding" Value="12,10" />
                                <Setter Property="BorderBrush" Value="#FFE2E8F0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridColumnHeader">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Height" Value="38" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFF1F5F9" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FFECFDF5" />
                                        <Setter Property="Foreground" Value="#FF047857" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="12,0" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                                <ContentPresenter VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Foreground}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mod Name" Binding="{Binding Name}" Width="130" />
                            <DataGridTextColumn Header="Spawn Name" Binding="{Binding SpawnName}" Width="130" />
                            <DataGridTextColumn Header="Installed Date" Binding="{Binding InstalledAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="170" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                            <DataGridTextColumn Header="Path" Binding="{Binding DlcRpfPath}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
