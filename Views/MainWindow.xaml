<Window x:Class="GtavOfflineModLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GTA V Offline Mod Launcher"
        Height="800"
        Width="1200"
        MinHeight="700"
        MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8FAFC"
        Icon="pack://application:,,,/Assets/GtavLauncher.ico"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <!-- Color Palette & Brushes (Premium Light Theme) -->
        <SolidColorBrush x:Key="WindowBgBrush" Color="#FFF8FAFC" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE2E8F0" />
        <SolidColorBrush x:Key="TextBrush" Color="#FF0F172A" />
        <SolidColorBrush x:Key="MutedBrush" Color="#FF64748B" />
        <SolidColorBrush x:Key="TitleBrush" Color="#FF0F172A" />

        <SolidColorBrush x:Key="AccentBrush" Color="#FF059669" /> <!-- Emerald 600 -->
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF047857" /> <!-- Emerald 700 -->
        <SolidColorBrush x:Key="AccentActiveBrush" Color="#FF065F46" /> <!-- Emerald 800 -->
        <SolidColorBrush x:Key="AccentLightBrush" Color="#FFECFDF5" /> <!-- Emerald 50 -->
        <SolidColorBrush x:Key="AccentBorderBrush" Color="#FF10B981" />

        <SolidColorBrush x:Key="DangerBrush" Color="#FFDC2626" /> <!-- Red 600 -->
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#FFB91C1C" /> <!-- Red 700 -->
        <SolidColorBrush x:Key="DangerActiveBrush" Color="#FF991B1B" /> <!-- Red 800 -->
        <SolidColorBrush x:Key="DangerBorderBrush" Color="#FFF87171" />

        <SolidColorBrush x:Key="SecondaryBrush" Color="#FFF1F5F9" /> <!-- Slate 100 -->
        <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#FFE2E8F0" /> <!-- Slate 200 -->
        <SolidColorBrush x:Key="SecondaryActiveBrush" Color="#FFF1F5F9" />
        <SolidColorBrush x:Key="SecondaryBorderBrush" Color="#FFE2E8F0" />

        <SolidColorBrush x:Key="InputBgBrush" Color="#FFF8FAFC" />
        <SolidColorBrush x:Key="InputFocusedBgBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#FFE2E8F0" />

        <!-- Fresh light gradient header banner -->
        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFECFDF5" Offset="0" />
            <GradientStop Color="#FFE0F2FE" Offset="0.5" />
            <GradientStop Color="#FFF3E8FF" Offset="1" />
        </LinearGradientBrush>

        <!-- Status Dot Style -->
        <Style x:Key="StatusDotStyle" TargetType="Border">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding GtaPath}" Value="">
                    <Setter Property="Background" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding GtaPath}" Value="{x:Null}">
                    <Setter Property="Background" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Card Style with soft shadow -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Color="#0F172A" Opacity="0.06" ShadowDepth="2" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style (Emerald Green) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentActiveBrush}" />
                                <Setter TargetName="Root" Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#FFE2E8F0" />
                                <Setter Property="Foreground" Value="#FF94A3B8" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="Transparent" />
                                <Setter TargetName="Root" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Play/Launch Button Style (Large Sky Blue) -->
        <Style x:Key="PlayButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#FF0284C7" /> <!-- Sky 600 -->
            <Setter Property="BorderBrush" Value="#FF0369A1" /> <!-- Sky 700 -->
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="24,0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Color="#FF0284C7" Opacity="0.2" ShadowDepth="0" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="▶  " FontSize="11" VerticalAlignment="Center" FontWeight="Normal" />
                                <ContentPresenter RecognizesAccessKey="True" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF0369A1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF0C4A6E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#FFE2E8F0" />
                                <Setter Property="Foreground" Value="#FF94A3B8" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="Transparent" />
                                <Setter Property="Effect" Value="{x:Null}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryBorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SecondaryHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFCBD5E1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFE2E8F0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#FFF8FAFC" />
                                <Setter Property="Foreground" Value="#FFCBD5E1" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="Transparent" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button Style -->
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource DangerHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource DangerActiveBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#FFE2E8F0" />
                                <Setter Property="Foreground" Value="#FF94A3B8" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="Transparent" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Global TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentLightBrush}" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FFCBD5E1"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="{StaticResource InputFocusedBgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="true">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                                <Setter TargetName="border" Property="Background" Value="#FFF1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Global CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent" SnapsToDevicePixels="true">
                            <BulletDecorator.Bullet>
                                <Border x:Name="BulletBorder"
                                        Width="18"
                                        Height="18"
                                        CornerRadius="4"
                                        BorderThickness="2"
                                        BorderBrush="{StaticResource CardBorderBrush}"
                                        Background="{StaticResource InputBgBrush}">
                                    <Path x:Name="CheckMark"
                                          Width="9"
                                          Height="7"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          SnapsToDevicePixels="False"
                                          Stroke="{StaticResource AccentBrush}"
                                          StrokeThickness="2"
                                          Data="M 1,3 L 3.5,6 L 8,1"
                                          Visibility="Collapsed" />
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="BulletBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="BulletBorder" Property="Background" Value="{StaticResource AccentLightBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="BulletBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Button for Activity Log -->
        <Style x:Key="LogToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="6">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="BtnText" Text="Show Activity Log" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"/>
                                <TextBlock x:Name="BtnArrow" Text="▲" VerticalAlignment="Center" FontSize="9"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#10000000" />
                                <Setter Property="Foreground" Value="{StaticResource TitleBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BtnText" Property="Text" Value="Hide Activity Log" />
                                <Setter TargetName="BtnArrow" Property="Text" Value="▼" />
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentLightBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Collapsible Log Border Style -->
        <Style x:Key="CollapsibleLogBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,16,0,0" />
            <Setter Property="Height" Value="0" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Color="#0F172A" Opacity="0.06" ShadowDepth="2" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=LogToggleBtn, Path=IsChecked}" Value="True">
                    <Setter Property="Height" Value="180" />
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="*" />    <!-- Content area -->
            <RowDefinition Height="Auto" /> <!-- Collapsible Log panel -->
            <RowDefinition Height="Auto" /> <!-- Status / Control bar -->
        </Grid.RowDefinitions>

        <!-- ROW 0: Sleek Header Banner (Light Theme) -->
        <Border Grid.Row="0"
                CornerRadius="14"
                Background="{StaticResource HeroBrush}"
                Padding="20"
                BorderBrush="#2010B981"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <Border Width="70"
                        Height="70"
                        CornerRadius="12"
                        Background="#2010B981"
                        BorderBrush="#4010B981"
                        BorderThickness="1"
                        Padding="10"
                        VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Assets/GtavLauncher.png" Stretch="Uniform" />
                </Border>

                <!-- App title info (Descriptive text and badges removed as requested) -->
                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource TitleBrush}"
                               Text="GTA V Offline Mod Launcher" />
                </StackPanel>

                <!-- Big Launch Game Action in the Header! -->
                <Button Grid.Column="2" 
                        Style="{StaticResource PlayButtonStyle}" 
                        Content="LAUNCH GTA V" 
                        Command="{Binding LaunchGtaOfflineCommand}"
                        Height="46"
                        Padding="24,0" 
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ROW 1: Content Area (Form on left, Mod List on right) -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Column: Install Form -->
            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Title & Description -->
                        <RowDefinition Height="*" />    <!-- Inputs stack -->
                        <RowDefinition Height="Auto" /> <!-- Install Button -->
                    </Grid.RowDefinitions>

                    <!-- Title & Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Text="Install a vehicle add-on" />
                        <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" FontSize="11.5" TextWrapping="Wrap" Text="Specify your GTA path, choose a dlc.rpf file, and type your mod details below." />
                    </StackPanel>

                    <!-- Form Inputs -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,0,4,0">
                            <!-- GTA Folder Path -->
                            <TextBlock Text="GTA V DIRECTORY" Foreground="{StaticResource MutedBrush}" FontSize="10.5" FontWeight="Bold" Margin="0,0,0,5"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding GtaPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Height="36" VerticalAlignment="Center" Margin="0"/>
                                <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="Browse" Command="{Binding BrowseGtaFolderCommand}" Margin="6,0,0,0" Padding="12,0" Height="36"/>
                            </Grid>

                            <!-- dlc.rpf file path -->
                            <TextBlock Text="DLC.RPF MOD FILE" Foreground="{StaticResource MutedBrush}" FontSize="10.5" FontWeight="Bold" Margin="0,0,0,5"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding SelectedDlcRpfPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Height="36" VerticalAlignment="Center" Margin="0"/>
                                <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="Select" Command="{Binding SelectDlcRpfCommand}" Margin="6,0,0,0" Padding="12,0" Height="36"/>
                            </Grid>

                            <!-- Mod Folder Name -->
                            <TextBlock Text="MOD FOLDER NAME" Foreground="{StaticResource MutedBrush}" FontSize="10.5" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding ModName, UpdateSourceTrigger=PropertyChanged}" Height="36" Margin="0,0,0,12"/>

                            <!-- Spawn Code -->
                            <TextBlock Text="VEHICLE SPAWN CODE" Foreground="{StaticResource MutedBrush}" FontSize="10.5" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding SpawnName, UpdateSourceTrigger=PropertyChanged}" Height="36" Margin="0,0,0,10"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Big Install Button at the bottom of the card -->
                    <Button Grid.Row="2" 
                            Style="{StaticResource PrimaryButtonStyle}" 
                            Content="Install Vehicle Mod" 
                            Command="{Binding InstallModCommand}" 
                            Height="40" 
                            Margin="0,8,0,0" />
                </Grid>
            </Border>

            <!-- Right Column: Installed Mods Table -->
            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Header Row -->
                        <RowDefinition Height="*" />    <!-- Grid Area -->
                        <RowDefinition Height="Auto" /> <!-- Grid Controls / Actions -->
                    </Grid.RowDefinitions>

                    <!-- Header Row -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Text="Installed Vehicle Mods" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Padding="8,4" CornerRadius="4" Background="#FFECFDF5" BorderBrush="#FF059669" BorderThickness="1" VerticalAlignment="Center">
                            <TextBlock Foreground="#FF065F46" FontWeight="Bold" FontSize="11" Text="{Binding InstalledMods.Count, StringFormat=TOTAL: {0}}" />
                        </Border>
                    </Grid>

                    <!-- DataGrid Table -->
                    <DataGrid Grid.Row="1"
                              Margin="0,14,0,0"
                              ItemsSource="{Binding InstalledMods}"
                              SelectedItem="{Binding SelectedInstalledMod}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#FFE2E8F0"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              Background="Transparent"
                              RowHeaderWidth="0"
                              SelectionUnit="FullRow">
                        <DataGrid.Resources>
                            <!-- Column Headers styling -->
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#FFF1F5F9" />
                                <Setter Property="Foreground" Value="#FF475569" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Padding" Value="12,10" />
                                <Setter Property="BorderBrush" Value="#FFE2E8F0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridColumnHeader">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Height" Value="40" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFF1F5F9" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentLightBrush}" />
                                        <Setter Property="Foreground" Value="#FF047857" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="12,0" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                                <ContentPresenter VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Foreground}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <!-- Columns Layout -->
                            <DataGridTextColumn Header="Mod Folder Name" Binding="{Binding Name}" Width="140" />
                            <DataGridTextColumn Header="Spawn Code" Binding="{Binding SpawnName}" Width="130" />
                            <DataGridTextColumn Header="Installed Date" Binding="{Binding InstalledAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="150" />
                            
                            <!-- Custom Status Column with green text indicator -->
                            <DataGridTemplateColumn Header="Status" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="6,2" CornerRadius="4" Background="#FFECFDF5" BorderBrush="#FFD1FAE5" BorderThickness="1" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Status}" Foreground="#FF065F46" FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Location Path" Binding="{Binding DlcRpfPath}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Table Controls at the bottom -->
                    <Grid Grid.Row="2" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- Refresh list -->
                        <Button Style="{StaticResource SecondaryButtonStyle}" 
                                Content="Refresh List" 
                                Command="{Binding RefreshInstalledModsCommand}" 
                                Height="36" Padding="14,0" HorizontalAlignment="Left" />
                        <!-- Uninstall Selected Mod -->
                        <Button Grid.Column="1" 
                                Style="{StaticResource DangerButtonStyle}" 
                                Content="Uninstall Selected Mod" 
                                Command="{Binding UninstallSelectedModCommand}" 
                                Height="36" Padding="16,0" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ROW 2: Collapsible Activity Log -->
        <Border Grid.Row="2" Style="{StaticResource CollapsibleLogBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Text="Activity Log" />

                <ListBox x:Name="LogListBox"
                         Grid.Row="1"
                         Margin="0,8,0,0"
                         ItemsSource="{Binding LogEntries}"
                         Background="#FFF8FAFC"
                         Foreground="{StaticResource TextBrush}"
                         BorderBrush="{StaticResource CardBorderBrush}"
                         BorderThickness="1"
                         Padding="6"
                         FontFamily="Consolas"
                         FontSize="11.5"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,0,4" />
                            <Setter Property="Padding" Value="8,5" />
                            <Setter Property="Background" Value="White" />
                            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="5"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <!-- ROW 3: Status / Control Bar -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left Side: Status Info -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- GTA V Path Status dot indicator -->
                <Border Style="{StaticResource StatusDotStyle}" VerticalAlignment="Center" Margin="0,0,6,0" />
                
                <TextBlock Text="GTA Path: " Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" FontSize="11.5" />
                <TextBlock Text="{Binding GtaPath}" Foreground="{StaticResource TitleBrush}" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Margin="0,0,24,0"/>

                <!-- Auto Edit Checkbox -->
                <CheckBox Content="Auto-Edit dlclist.xml" IsChecked="{Binding AutoEditDlclist}" VerticalAlignment="Center" FontSize="11.5" />
            </StackPanel>

            <!-- Right Side: Log Drawer Toggle -->
            <ToggleButton x:Name="LogToggleBtn" Grid.Column="1" Style="{StaticResource LogToggleButtonStyle}" />
        </Grid>
    </Grid>
</Window>
